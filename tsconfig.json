{
  "include": ["src", "test", "script"],
  "exclude": ["dist"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "isolatedDeclarations": true,
    "types": [],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
