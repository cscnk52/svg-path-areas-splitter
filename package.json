{
  "name": "svg-path-areas-splitter",
  "version": "0.0.2",
  "description": "Split SVG path d strings into individual area sub-paths",
  "keywords": [
    "area",
    "geometry",
    "path",
    "split",
    "svg"
  ],
  "license": "MIT",
  "author": "Cason Kervis",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": "./dist/index.mjs",
  "scripts": {
    "prepublishOnly": "bun run test && bun run build && bun run publint",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "colorize": "bun run script/colorize.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "publint": "publint",
    "format": "oxfmt"
  },
  "dependencies": {
    "svg-pathdata": "^8.0.0",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@types/node": "^25.3.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "publint": "^0.3.18",
    "simple-icons": "^16.10.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.10"
}
