{
  "name": "svg-path-areas-splitter",
  "version": "0.1.0",
  "description": "Split SVG path d strings into individual area sub-paths",
  "keywords": [
    "area",
    "geometry",
    "path",
    "split",
    "svg"
  ],
  "license": "MIT",
  "author": "Cason Kervis",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "bun run test && bun run build && bun run publint",
    "publint": "publint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "svg-pathdata": "^9.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@inquirer/search": "4.1.7",
    "@vitest/coverage-istanbul": "^4.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "publint": "^0.3.18",
    "simple-icons": "^16.16.0",
    "ts-pattern": "^5.9.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
