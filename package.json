{
  "name": "svg-path-areas-splitter",
  "version": "0.1.1",
  "description": "Split SVG path d strings into individual area sub-paths",
  "keywords": [
    "area",
    "geometry",
    "path",
    "split",
    "svg"
  ],
  "license": "MIT",
  "author": "Cason Kervis",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "bun run test && bun run build && bun run publint",
    "publint": "publint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "svg-pathdata": "9.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@inquirer/search": "^4.1.8",
    "@vitest/coverage-istanbul": "^4.1.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "publint": "^0.3.19",
    "simple-icons": "^16.18.1",
    "ts-pattern": "^5.9.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
